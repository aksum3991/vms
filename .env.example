# Database
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?schema=public"

# Environment
NODE_ENV=development

# Application Base URL (for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Security
JWT_SECRET=<YOUR_JWT_SECRET>
ENCRYPTION_KEY=<YOUR_ENCRYPTION_KEY>

# OpenAI
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<YOUR_NEXTAUTH_SECRET>"

# Keycloak (Auth)
AUTH_KEYCLOAK_ID="<KEYCLOAK_CLIENT_ID>"
AUTH_KEYCLOAK_SECRET="<KEYCLOAK_CLIENT_SECRET>"
AUTH_KEYCLOAK_ISSUER="http://127.0.0.1:8082/realms/<REALM_NAME>"

# Public Keycloak (Client-side)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID="<KEYCLOAK_CLIENT_ID>"
NEXT_PUBLIC_KEYCLOAK_ISSUER="http://127.0.0.1:8082/realms/<REALM_NAME>"

# Keycloak Admin
KC_ADMIN_CLIENT_ID="<ADMIN_CLIENT_ID>"
KC_ADMIN_CLIENT_SECRET="<ADMIN_CLIENT_SECRET>"
KC_ADMIN_BASE="http://127.0.0.1:8082/admin/realms/<REALM_NAME>"