
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// MULTI-TENANT: Tenant model (one row per organisation using the platform)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique   // URL-safe slug, e.g. "mint" → /t/mint/...
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users                  User[]
  requests               Request[]
  guests                 Guest[]
  surveys                Survey[]
  settings               Settings?
  notifications          Notification[]
  notificationDispatches NotificationDispatch[]
  blacklistEntries       BlacklistEntry[]
  auditLogs              AuditLog[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER — tenant-scoped; superadmin has tenantId = null
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String
  password      String
  name          String
  role          UserRole @default(requester)
  assignedGates String[]
  active        Boolean  @default(true)
  language      String   @default("en")
  phone         String?
  createdAt     DateTime @default(now())

  // Multi-tenant: nullable for superadmin, required for all other roles
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])

  requests          Request[]     @relation("RequestedBy")
  withdrawnRequests Request[]     @relation("WithdrawnBy")
  notifications     Notification[]
  auditLogs         AuditLog[]

  // Email unique per tenant (not globally)
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// REQUEST
// ─────────────────────────────────────────────────────────────────────────────

model Request {
  id                 String   @id @default(cuid())
  approvalNumber     String?
  requestedById      String
  requestedByEmail   String
  destination        String
  gate               String
  fromDate           DateTime
  toDate             DateTime
  purpose            String
  status             Status   @default(submitted)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  approver1Comment   String?
  approver1Date      DateTime?
  approver1By        String?
  approver2Comment   String?
  approver2Date      DateTime?
  approver2By        String?
  withdrawnAt        DateTime?
  withdrawnById      String?
  withdrawalReason   String?

  // Multi-tenant
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  requestedBy User   @relation("RequestedBy", fields: [requestedById], references: [id])
  withdrawnBy User?  @relation("WithdrawnBy", fields: [withdrawnById], references: [id])
  guests      Guest[]
  surveys     Survey[]

  @@unique([tenantId, approvalNumber])   // approval number unique per tenant
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// GUEST — own tenantId column (not inherited from Request)
// ─────────────────────────────────────────────────────────────────────────────

model Guest {
  id                      String   @id @default(cuid())
  name                    String
  organization            String
  email                   String?
  phone                   String?
  laptop                  Boolean  @default(false)
  mobile                  Boolean  @default(false)
  flash                   Boolean  @default(false)
  otherDevice             Boolean  @default(false)
  otherDeviceDescription  String?
  idPhotoUrl              String?
  checkInTime             DateTime?
  checkOutTime            DateTime?
  approver1Status         String?
  approver2Status         String?
  approver1Comment        String?
  approver2Comment        String?
  preferredLanguage       String   @default("en")

  // Multi-tenant (redundant with Request.tenantId for direct queries)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  Survey    Survey?

  @@index([tenantId, checkInTime])
  @@index([tenantId, approver2Status])
  @@map("guests")
}

// ─────────────────────────────────────────────────────────────────────────────
// SURVEY — own tenantId column
// ─────────────────────────────────────────────────────────────────────────────

model Survey {
  id          String   @id @default(cuid())
  requestId   String
  guestId     String   @unique
  rating      Int
  comment     String
  submittedAt DateTime @default(now())

  // Multi-tenant
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  request Request @relation(fields: [requestId], references: [id])
  guest   Guest   @relation(fields: [guestId], references: [id])

  @@index([tenantId, submittedAt])
  @@map("surveys")
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTINGS — one row per tenant (was singleton id=1)
// ─────────────────────────────────────────────────────────────────────────────

model Settings {
  id                      String   @id @default(cuid())  // was: Int @id @default(1)
  approvalSteps           Int      @default(2)
  emailNotifications      Boolean  @default(true)
  smsNotifications        Boolean  @default(true)
  checkInOutNotifications Boolean  @default(true)
  gates                   String[]
  primaryColor            String?
  accentColor             String?
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPassword            String?
  smsGatewayUrl           String?
  smsApiKey               String?
  emailGatewayUrl         String?
  emailApiKey             String?
  defaultLanguage         String   @default("en")

  // Multi-tenant — unique ensures one settings row per tenant
  tenantId  String  @unique
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  requestId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Multi-tenant
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  user       User     @relation(fields: [userId], references: [id])
  dispatches NotificationDispatch[]

  @@index([tenantId, userId])
  @@index([tenantId, read])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION DISPATCH — own tenantId for outbox queries
// ─────────────────────────────────────────────────────────────────────────────

model NotificationDispatch {
  id             String                     @id @default(cuid())
  notificationId String
  channel        NotificationChannel
  recipient      String
  subject        String?
  body           String
  html           String?
  attachments    Json?
  status         NotificationDispatchStatus @default(queued)
  provider       String?
  attempts       Int                        @default(0)
  lastError      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  // Multi-tenant (redundant for outbox processing without joining Notification)
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, status])
  @@index([tenantId, status])
  @@map("notification_dispatches")
}

// ─────────────────────────────────────────────────────────────────────────────
// BLACKLIST ENTRY
// ─────────────────────────────────────────────────────────────────────────────

model BlacklistEntry {
  id           String    @id @default(cuid())
  name         String
  organization String?
  email        String?
  phone        String?
  reason       String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  // Multi-tenant
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("blacklist_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG — tenantId nullable (superadmin platform actions have no tenant)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   Json
  timestamp DateTime @default(now())
  userId    String

  // Multi-tenant — nullable for superadmin actions
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, timestamp])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Status {
  draft
  submitted
  host_pending
  approver1_pending
  approver1_approved
  approver1_rejected
  approver2_pending
  approver2_approved
  approver2_rejected
  withdrawn
}

enum UserRole {
  superadmin   // platform-level, tenantId = null
  admin        // tenant-level admin
  requester
  approver1
  approver2
  reception
}

enum NotificationChannel {
  email
  sms
}

enum NotificationDispatchStatus {
  queued
  sent
  failed
}
